{
  "name": "teutonia-next",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:marketing": "npm run dev --workspace @teutonia/marketing",
    "dev:app": "npm run dev --workspace @teutonia/app",
    "build:marketing": "npm run build --workspace @teutonia/marketing",
    "build:app": "npm run build --workspace @teutonia/app",
    "lint:marketing": "npm run lint --workspace @teutonia/marketing",
    "lint:app": "npm run lint --workspace @teutonia/app"
  }
}
